# ───── Anthropic (Claude API) ─────
ANTHROPIC_API_KEY=

# ───── Google OAuth 2.0 ─────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ───── Google Drive Service Account ─────
# Paste ทั้งไฟล์ JSON ลงไปในบรรทัดเดียว (escape newlines or use raw JSON)
# Production (Render): ใส่ใน env var นี้
# Local dev: ใส่ใน env var นี้ หรือใส่ไฟล์ path ใน GOOGLE_CREDENTIALS_FILE
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_CREDENTIALS_FILE=./service-account.json

# ───── Supabase ─────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=

# ───── Frontend base URL (for CORS / links) ─────
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ───── Deploy approval email (Gmail SMTP) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
